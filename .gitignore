# pyenv
#   For a library or package, you might want to ignore these files since the Python version is
#   often set at the user or system level. In those cases, you may want to comment out the next line.
# .python-version

# pipenv
#   According to pypa/pipenv#1191, it is recommended to not .gitignore Pipfile.lock.
#   If you must, uncomment the next line:
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   If you must, uncomment the next line:
#poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
#   If you must, uncomment the next line:
#pdm.lock

# PEP 582; used by e.g. pdm.
__pypackages__/

